---
import Layout from '~/layouts/PageLayout.astro';
import Carrito from '~/components/Carrito.astro';
import { getCollection } from 'astro:content';
import { waLink, descuento } from '~/data/tienda';

const metadata = {
  title: 'ABC Tendencia — Peluches y novedades virales en Huánuco · Delivery Huánuco y envíos a todo el Perú',
  ignoreTitleTemplate: true,
};

const productos = (await getCollection('productos', (p) => p.data.activo)).sort(
  (a, b) => (a.data.orden ?? 0) - (b.data.orden ?? 0)
);
const categorias = ['Todos', 'Peluches', 'Novedades'];

const pasos = [
  { n: '1', t: 'Elige tus peluches', d: 'Explora el catálogo y busca lo que más te guste.', e: '🧸' },
  { n: '2', t: 'Agrégalos al carrito', d: 'Suma todo lo que quieras pedir en un solo lugar.', e: '🛒' },
  { n: '3', t: 'Envía tu pedido', d: 'Toca "Enviar por WhatsApp" y coordinamos pago y envío.', e: '💬' },
];
const pagos = ['💜 Yape', '💙 Plin', '🏦 Transferencia', '📦 Contra entrega', '🚚 Olva Courier', '🚚 Shalom'];

const faqs = [
  { q: '¿Hacen envíos a todo el Perú?', a: 'Sí, enviamos a todo el país por agencia (Olva, Shalom y otras). En Huánuco también hacemos delivery.' },
  { q: '¿Dónde están ubicados?', a: 'Estamos en Huánuco, Perú. Hacemos delivery dentro de Huánuco y enviamos a todo el país por agencia.' },
  { q: '¿Cómo hago mi pedido?', a: 'Muy fácil: agrega tus peluches al carrito y toca "Enviar pedido por WhatsApp". Te atendemos al instante.' },
  { q: '¿Qué formas de pago aceptan?', a: 'Aceptamos Yape, Plin, transferencia bancaria y, según la zona, pago contra entrega.' },
  { q: '¿Los peluches son de buena calidad?', a: '¡Claro! Seleccionamos peluches suaves y de buena calidad para que tu regalo sea perfecto.' },
  { q: '¿Puedo pedir un peluche que vi en TikTok?', a: 'Sí, traemos lo más viral. Escríbenos por WhatsApp con la referencia y te ayudamos a conseguirlo.' },
];

const site = Astro.site?.href ?? 'https://abctendencia.netlify.app/';
const jsonLdStore = {
  '@context': 'https://schema.org', '@type': 'Store', name: 'ABC Tendencia',
  description: 'Tienda de peluches y productos virales en tendencia en Huánuco, Perú. Delivery en Huánuco y envíos a todo el Perú.',
  image: new URL('/logo.png', site).href, url: site, telephone: '+51991505772',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Huánuco',
    addressRegion: 'Huánuco',
    addressCountry: 'PE',
  },
  areaServed: [
    { '@type': 'City', name: 'Huánuco' },
    { '@type': 'Country', name: 'Perú' },
  ],
  sameAs: ['https://www.instagram.com/abc.tendencia', 'https://www.facebook.com/share/1cAL7LMnkk/', 'https://www.tiktok.com/@abc.tendencia'],
};
const jsonLdFaq = {
  '@context': 'https://schema.org', '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
};
---

<Layout metadata={metadata}>
  <!-- HERO -->
  <section class="relative overflow-hidden text-white" style="background:linear-gradient(135deg,#38B6E0 0%,#6E56F0 55%,#7C5CFC 100%)">
    <div class="pointer-events-none absolute -top-24 -right-24 w-96 h-96 rounded-full bg-white/10 blur-3xl"></div>
    <div class="pointer-events-none absolute -bottom-32 -left-24 w-96 h-96 rounded-full bg-white/10 blur-3xl"></div>
    <div class="relative max-w-7xl mx-auto px-4 pt-10 pb-16 md:pt-20 md:pb-32 grid md:grid-cols-2 gap-5 md:gap-8 items-center">
      <!-- Texto -->
      <div class="text-center md:text-left">
        <span class="inline-flex items-center gap-2 rounded-full bg-white/15 px-4 py-1.5 text-sm font-semibold ring-1 ring-white/25 backdrop-blur">
          🔥 Lo más viral en Huánuco
        </span>
        <h1 class="mt-4 text-3xl sm:text-5xl md:text-6xl font-extrabold leading-[1.08] tracking-tight">
          Peluches y novedades <span class="text-[#FFD84D]">que enamoran</span>
        </h1>
        <p class="mt-3 text-base md:text-xl text-white/90 max-w-md mx-auto md:mx-0">
          Lo más viral de TikTok, directo a tu puerta. Delivery en Huánuco y envíos a todo el Perú 🇵🇪
        </p>
        <!-- Botón + confianza: solo en desktop van aquí -->
        <div class="hidden md:block">
          <div class="mt-7">
            <a href="#catalogo"
              class="inline-flex items-center justify-center gap-2 rounded-full bg-white text-[#7C5CFC] font-bold text-lg px-9 py-4 shadow-lg hover:shadow-xl hover:-translate-y-0.5 transition">
              🛍️ Ver catálogo
            </a>
          </div>
          <div class="mt-6 flex flex-wrap gap-x-5 gap-y-1.5 text-sm text-white/85 font-medium">
            <span>✓ Envíos a todo el Perú</span>
            <span>✓ Pago contra entrega</span>
          </div>
        </div>
      </div>
      <!-- Peluches recortados flotando (estilo tienda) -->
      <div class="relative mx-auto w-full max-w-[16rem] sm:max-w-sm md:max-w-2xl">
        <div class="pointer-events-none absolute inset-x-2 top-2 bottom-6 rounded-[3rem] bg-white/10 blur-2xl"></div>
        <div class="relative flex items-end justify-center">
          <img src="/img/hero/ghostface.png" alt="Peluche Ghostface viral" width="520" height="520" loading="eager"
            class="w-[50%] rotate-[-6deg] -mr-[22%] mb-6 relative z-0" style="filter:drop-shadow(0 16px 20px rgba(0,0,0,.35))" />
          <img src="/img/hero/kirby.png" alt="Peluche Kirby" width="700" height="700" loading="eager"
            class="w-[62%] relative z-10" style="filter:drop-shadow(0 22px 26px rgba(0,0,0,.4))" />
          <img src="/img/hero/vaca.png" alt="Peluche Vaquita correlona" width="520" height="520" loading="eager"
            class="w-[50%] rotate-[6deg] -ml-[22%] mb-6 relative z-0" style="filter:drop-shadow(0 16px 20px rgba(0,0,0,.35))" />
        </div>
        <div class="mt-3 hidden md:flex justify-center">
          <span class="inline-flex items-center gap-2 rounded-full bg-white text-gray-800 px-4 py-2 text-sm font-bold shadow-xl">🚚 Delivery en Huánuco · Envíos a todo el Perú</span>
        </div>
      </div>
      <!-- Botón + confianza: solo en móvil, después de los peluches -->
      <div class="md:hidden text-center mt-1">
        <a href="#catalogo"
          class="inline-flex w-full max-w-xs items-center justify-center gap-2 rounded-full bg-white text-[#7C5CFC] font-extrabold text-lg px-8 py-4 shadow-lg transition active:scale-95">
          🛍️ Ver catálogo
        </a>
        <div class="mt-4 flex flex-wrap gap-x-4 gap-y-1 justify-center text-sm text-white/85 font-medium">
          <span>✓ Envíos a todo el Perú</span>
          <span>✓ Pago contra entrega</span>
        </div>
      </div>
    </div>
    <svg class="absolute bottom-0 left-0 w-full text-white" style="height:60px" viewBox="0 0 1440 80" fill="none" preserveAspectRatio="none" aria-hidden="true">
      <path d="M0,40 C320,90 560,10 720,30 C920,55 1180,95 1440,35 L1440,80 L0,80 Z" fill="currentColor" />
    </svg>
  </section>

  <!-- Franja de confianza -->
  <section class="bg-white border-b border-gray-100">
    <div class="max-w-5xl mx-auto px-4 py-3 flex flex-wrap justify-center gap-x-6 gap-y-1 text-sm font-semibold text-gray-600">
      <span>✅ Delivery en Huánuco</span>
      <span class="text-gray-300">|</span>
      <span>✅ Envíos a todo el Perú</span>
      <span class="text-gray-300">|</span>
      <span>✅ Pago seguro</span>
      <span class="text-gray-300">|</span>
      <span>✅ Atención por WhatsApp</span>
    </div>
  </section>

  <section id="catalogo" class="px-4 pt-8 pb-12 sm:pb-16">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-7">
        <p class="text-base font-bold tracking-wide uppercase" style="color:#38B6E0">🔥 Catálogo</p>
        <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight mt-1">Nuestros peluches y <span style="color:#7C5CFC">novedades</span></h2>
      </div>

      <div class="max-w-md mx-auto mb-6">
        <input id="buscar" type="search" placeholder="🔍 Busca tu peluche..."
          class="w-full rounded-full border-2 border-gray-200 px-5 py-3 focus:border-[#7C5CFC] focus:outline-none transition" />
      </div>

      <div class="flex flex-wrap justify-center gap-3 mb-9">
        {categorias.map((c, i) => (
          <button
            class:list={['chip px-5 py-2 rounded-full font-semibold border-2 transition', i === 0 ? 'chip-activo' : 'bg-white border-gray-200 text-gray-700']}
            data-cat={c}
          >{c}</button>
        ))}
      </div>

      <div id="grid" class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 sm:gap-6">
        {productos.map((p) => {
          const d = descuento(p.data.precio, p.data.precioAntes);
          return (
            <article class="prod bg-white rounded-3xl shadow-lg overflow-hidden flex flex-col transition hover:-translate-y-1.5 hover:shadow-2xl"
              data-cat={p.data.categoria} data-nombre={p.data.nombre.toLowerCase()}>
              <div class="relative aspect-square overflow-hidden bg-[#f4f5fa]">
                {p.data.destacado && <span class="absolute top-3 left-3 z-10 text-white text-xs font-bold px-3 py-1 rounded-full" style="background:linear-gradient(135deg,#FF4D8D,#FF6B57)">🔥 Viral</span>}
                {d && <span class="absolute top-3 right-3 z-10 text-xs font-bold px-3 py-1 rounded-full" style="background:linear-gradient(135deg,#FFC02E,#FF8A3D);color:#5a3d00">-{d}%</span>}
                <a href={`/producto/${p.id}`}>
                  <img src={p.data.imagen} alt={p.data.nombre} loading="lazy" class="w-full h-full object-cover transition duration-300 hover:scale-105" />
                </a>
              </div>
              <div class="p-4 flex flex-col gap-2 flex-1">
                <a href={`/producto/${p.id}`} class="font-bold text-gray-800 leading-tight hover:text-[#7C5CFC]">{p.data.nombre}</a>
                {p.data.tamano && (
                  <span class="self-start inline-flex items-center gap-1 rounded-full bg-gray-100 text-gray-600 text-xs font-semibold px-2.5 py-1">📏 {p.data.tamano}</span>
                )}
                <div class="flex items-baseline gap-2">
                  <span class="text-xl font-extrabold" style="color:#7C5CFC">S/ {p.data.precio}</span>
                  {p.data.precioAntes && <span class="text-sm text-gray-400 line-through">S/ {p.data.precioAntes}</span>}
                </div>
                {p.data.stock > 0 && p.data.stock <= 3 && <span class="text-xs font-bold text-red-500">⚡ ¡Solo quedan {p.data.stock}!</span>}
                <button class="add-cart mt-auto text-white font-extrabold py-3 rounded-full shadow-md hover:shadow-lg hover:-translate-y-0.5 active:scale-95 transition"
                  style="background:linear-gradient(135deg,#38B6E0,#7C5CFC)"
                  data-id={p.id} data-nombre={p.data.nombre} data-precio={p.data.precio} data-img={p.data.imagen}>🛒 Agregar</button>
              </div>
            </article>
          );
        })}
      </div>
      <p id="sin-resultados" class="hidden text-center text-gray-500 py-10">No encontramos peluches con ese nombre 🧸</p>
    </div>
  </section>

  <!-- Cómo comprar -->
  <section id="como-comprar" class="px-4 py-14 bg-white">
    <div class="max-w-5xl mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight mb-3">¿Cómo comprar? Súper <span style="color:#7C5CFC">fácil</span></h2>
      <p class="text-gray-500 mb-10">En 3 pasos tu pedido está en camino</p>
      <div class="grid sm:grid-cols-3 gap-6">
        {pasos.map((p) => (
          <div class="bg-gray-50 rounded-3xl p-7 relative">
            <div class="w-12 h-12 mx-auto rounded-full text-white font-extrabold text-lg flex items-center justify-center mb-4" style="background:linear-gradient(135deg,#38B6E0,#7C5CFC)">{p.n}</div>
            <div class="text-4xl mb-2">{p.e}</div>
            <h3 class="font-bold text-lg text-gray-800 mb-1">{p.t}</h3>
            <p class="text-gray-500 text-sm">{p.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Medios de pago y envío -->
  <section class="px-4 py-8 bg-gray-50 border-y border-gray-100">
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-gray-500 font-semibold mb-4 uppercase text-sm tracking-wide">Pagos y envíos</p>
      <div class="flex flex-wrap justify-center gap-3">
        {pagos.map((m) => (
          <span class="bg-white border border-gray-200 rounded-full px-4 py-2 text-sm font-semibold text-gray-700 shadow-sm">{m}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section id="faq" class="px-4 py-12 bg-white">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-3xl font-extrabold tracking-tight text-center mb-8">Preguntas <span style="color:#7C5CFC">frecuentes</span></h2>
      <div class="space-y-4">
        {faqs.map((f) => (
          <details class="bg-gray-50 rounded-2xl shadow-sm p-5 group">
            <summary class="font-bold text-gray-800 cursor-pointer list-none flex justify-between items-center">
              {f.q}<span class="text-[#7C5CFC] group-open:rotate-45 transition">+</span>
            </summary>
            <p class="text-gray-600 mt-3">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section id="contacto" class="px-4 py-14" style="background:linear-gradient(135deg,#E3F4FC,#EDE7FF 55%,#FFE8F1)">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight mb-3">¿Listo para <span style="color:#7C5CFC">sorprender</span>?</h2>
      <p class="text-lg text-gray-600 mb-4">Arma tu carrito o escríbenos por WhatsApp. Delivery en Huánuco y envíos a todo el Perú 🇵🇪</p>
      <p class="inline-flex items-center gap-2 bg-white/70 text-gray-700 font-semibold rounded-full px-5 py-2 mb-7 shadow-sm">📍 Ubicados en Huánuco, Perú</p>
      <div class="flex justify-center">
        <a href={waLink('Hola ABC Tendencia 🐼, quiero hacer un pedido')} target="_blank" rel="noopener"
          class="inline-flex items-center gap-2 bg-[#25D366] hover:brightness-105 text-white font-bold text-lg px-8 py-4 rounded-full shadow-lg transition">
          💬 Escríbenos por WhatsApp
        </a>
      </div>
    </div>
  </section>

  <Carrito />

  <script type="application/ld+json" set:html={JSON.stringify(jsonLdStore)} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} is:inline />
</Layout>

<style>
  .chip-activo{background:linear-gradient(135deg,#38B6E0,#7C5CFC);color:#fff;border-color:transparent;}
</style>

<script is:inline>
  const chips = document.querySelectorAll('.chip');
  const prods = Array.from(document.querySelectorAll('.prod'));
  const buscar = document.getElementById('buscar');
  const sinRes = document.getElementById('sin-resultados');
  let catActiva = 'Todos';

  function aplicar() {
    const q = (buscar.value || '').trim().toLowerCase();
    let visibles = 0;
    prods.forEach((p) => {
      const okCat = catActiva === 'Todos' || p.getAttribute('data-cat') === catActiva;
      const okQ = !q || (p.getAttribute('data-nombre') || '').includes(q);
      const show = okCat && okQ;
      p.style.display = show ? '' : 'none';
      if (show) visibles++;
    });
    sinRes.classList.toggle('hidden', visibles > 0);
  }
  chips.forEach((chip) => {
    chip.addEventListener('click', () => {
      chips.forEach((c) => { c.classList.remove('chip-activo'); c.classList.add('bg-white', 'border-gray-200', 'text-gray-700'); });
      chip.classList.add('chip-activo'); chip.classList.remove('bg-white', 'border-gray-200', 'text-gray-700');
      catActiva = chip.getAttribute('data-cat');
      aplicar();
    });
  });
  buscar.addEventListener('input', aplicar);

  function desdeHash() {
    const h = decodeURIComponent(location.hash.replace('#', '')).toLowerCase();
    const map = { peluches: 'Peluches', novedades: 'Novedades', catalogo: 'Todos' };
    if (map[h]) {
      const chip = Array.from(chips).find((c) => c.getAttribute('data-cat') === map[h]);
      if (chip) chip.click();
      document.getElementById('catalogo').scrollIntoView({ behavior: 'smooth' });
    }
  }
  window.addEventListener('hashchange', desdeHash);
  desdeHash();
</script>
