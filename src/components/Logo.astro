---
import { SITE } from 'astrowind:config';
---

<span class="flex items-center gap-2 self-center rtl:ml-0 rtl:mr-2 whitespace-nowrap">
  <img src="/logo.png" alt={SITE?.name} class="w-11 h-11 rounded-full shadow-md" width="44" height="44" loading="eager" />
  <span class="text-2xl md:text-xl font-bold text-gray-900 dark:text-white">{SITE?.name}</span>
</span>
